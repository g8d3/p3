# Content Automation System Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# LLM API Keys (at least one recommended)
# ==========================================
# OpenAI API key for content generation
OPENAI_API_KEY=

# Anthropic API key for content generation
ANTHROPIC_API_KEY=

# ==========================================
# Social Media API Keys (optional)
# ==========================================
# Twitter/X API credentials
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Facebook Page Access Token
FACEBOOK_ACCESS_TOKEN=

# LinkedIn Access Token
LINKEDIN_ACCESS_TOKEN=

# Instagram Access Token
INSTAGRAM_ACCESS_TOKEN=

# ==========================================
# Data Source Keys (optional)
# ==========================================
# GitHub Personal Access Token (for API rate limits)
GITHUB_TOKEN=

# Reddit API credentials
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ContentAutomationBot/1.0

# NewsAPI.org key
NEWS_API_KEY=

# ==========================================
# Application Settings
# ==========================================
# Database URL (SQLite by default)
DATABASE_URL=sqlite:///./content_automation.db

# Redis URL (optional, for caching)
REDIS_URL=redis://localhost:6379

# Content generation settings
MAX_CONTENT_LENGTH=2000
CONTENT_TEMPERATURE=0.7

# Scheduling settings
DEFAULT_POST_INTERVAL_HOURS=6
MAX_POSTS_PER_DAY=4

# Debug mode (set to True for development)
DEBUG=False