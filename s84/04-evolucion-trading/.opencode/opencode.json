{
  "$schema": "https://opencode.ai/config.json",
  "model": "proxy/deepseek-v4-flash",

  "provider": {
    "proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Proxy Local",
      "options": {
        "baseURL": "http://localhost:9098/v1",
        "apiKey": "{env:OPENCODE_GO_API_KEY}",
        "headers": { "X-Agent-ID": "evt" }
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (proxy)"
        }
      }
    }
  }
}
