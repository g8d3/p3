# ── Required ──────────────────────────────────────────────────────────────
OPENCODE_GO_API_KEY=sk-...     # Script generation (OpenAI-compatible)
INWORLD_API_KEY=...            # TTS voiceover (Base64-encoded key from Inworld)

# ── Optional: Stock video background ──────────────────────────────────────
# Get a free key: https://www.pexels.com/api/
PEXELS_API_KEY=...

# ── Optional: Background music ────────────────────────────────────────────
# Get a free key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=...

# ── Optional: YouTube upload ──────────────────────────────────────────────
YT_CLIENT_SECRET=/path/to/client_secret.json  # Google OAuth
YT_TOKEN_PATH=/home/user/.yt_token.json       # Token cache

# ── Optional: Model selection ─────────────────────────────────────────────
OPENCODE_GO_MODEL=deepseek-v4-flash  # or glm-5, deepseek-v4-pro, etc.
