    "better-sqlite3": "^11.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.7.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/ws": "^8.5.10",
    "vitest": "^3.0.0"
  }
}
