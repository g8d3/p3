# Hyperliquid Configuration
HYPERLIQUID_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
# Use testnet: https://api.hyperliquid-testnet.xyz

# Trading Configuration
TRADING_COINS=ETH,BTC,SOL
MAX_POSITION_SIZE_USD=1000
MAX_LEVERAGE=3
RISK_PER_TRADE=0.02

# Signal Configuration
SIGNAL_LOOKBACK_DAYS=30
COMBINATION_WINDOW_DAYS=60
MIN_SIGNAL_HISTORY=20

# Logging
LOG_LEVEL=INFO
