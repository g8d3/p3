#!/bin/bash
# supervisor — health monitor daemon with stats + escalation
# Checks every N seconds that agents and busd are alive, restarts if dead.
# Tracks crash counts, escalates if crash loop detected.
# Usage: supervisor <N> <interval_secs> [xdg_data_dir]

n=${1:-3}
interval=${2:-4}
busdir="/tmp/agent-bus"
self_dir="$(cd "$(dirname "$0")" && pwd)"

# XDG paths for persistent data
XDG_DATA="${3:-$HOME/.local/share/orquestar-agentes}"
stats_file="$XDG_DATA/stats.json"
logfile="$XDG_DATA/supervisor.log"

mkdir -p "$XDG_DATA" "$busdir"

log() { echo "[$(date +%H:%M:%S)] $*" >> "$logfile"; }

# Rate-limited notification — writes to inbox only if N seconds have passed since last notify
notify_agent() {
  local agent="$1"
  local msg="$2"
  local cooldown="${3:-30}"  # default 30s between identical messages
  local key=$(echo "$msg" | md5sum | head -c 8)
  local last_file="$busdir/.notify-$agent-$key"
  local last=$(cat "$last_file" 2>/dev/null || echo 0)
  local now=$(date +%s)
  if [ $((now - last)) -gt "$cooldown" ]; then
    echo "$msg" > "$busdir/$agent/in/.supervisor-$(date +%s)"
    echo "$now" > "$last_file"
    return 0
  fi
  return 1
}

# Stats helpers
read_stats() {
  if [ -f "$stats_file" ]; then cat "$stats_file"; else echo '{}'; fi
}

write_stats() { echo "$1" > "$stats_file"; }

record_crash() {
  local agent="$1"
  local now=$(date +%s)
  local stats=$(read_stats)
  local agent_stats=$(echo "$stats" | jq -r ".[\"$agent\"] // {}" 2>/dev/null || echo '{}')
  local crashes=$(echo "$agent_stats" | jq -r '.crashes // 0' 2>/dev/null || echo 0)
  local starts=$(echo "$agent_stats" | jq -r '.starts // 0' 2>/dev/null || echo 0)
  local crash_times=$(echo "$agent_stats" | jq -r '.crash_times // []' 2>/dev/null || echo '[]')

  crashes=$((crashes + 1))
  crash_times=$(echo "$crash_times" | jq ". + [$now] | .[-20:]" 2>/dev/null || echo "[$now]")

  # Count crashes in last 5 minutes
  local recent=$(echo "$crash_times" | jq "[.[] | select(. > $((now - 300)))] | length" 2>/dev/null || echo 1)

  local new_stats=$(echo "$agent_stats" | jq ". + {crashes: $crashes, crash_times: $crash_times, last_crash: $now, starts: $starts}" 2>/dev/null)
  stats=$(echo "$stats" | jq ".[\"$agent\"] = $new_stats" 2>/dev/null)
  write_stats "$stats"

  log "$agent: crash #$crashes ($recent in last 5min)"

  # Escalate if crash loop detected (≥5 in 5min)
  if [ "$recent" -ge 5 ]; then
    log "$agent: CRASH LOOP detected ($recent crashes in 5min), escalating"
    local last_output=$(tmux capture-pane -t "$agent" -p -S -20 2>/dev/null | head -30)
    mkdir -p "$busdir/a1/tasks"
    cat > "$busdir/a1/tasks/escalation-$agent-$(date +%s)" << TASKEOF
INSTRUCCIÓN PARA MAKER

ALERTA: el agente $agent ha fallado $recent veces en los últimos 5 minutos.

Última salida del agente:
$(echo "$last_output" | tail -10)

Ejecuta:
1. Revisa si el agente tiene un error recurrente (skill corrupta, config inválida)
2. Si hay un error en los archivos de skill, corrige
3. Verifica que el agente pueda iniciar correctamente
4. say checker "escalación $agent resuelta"
TASKEOF
    log "$agent: escalation task written to a1/tasks/"
  fi
}

record_start() {
  local agent="$1"
  local now=$(date +%s)
  local stats=$(read_stats)
  local agent_stats=$(echo "$stats" | jq -r ".[\"$agent\"] // {}" 2>/dev/null || echo '{}')
  local starts=$(echo "$agent_stats" | jq -r '.starts // 0' 2>/dev/null || echo 0)
  starts=$((starts + 1))
  agent_stats=$(echo "$agent_stats" | jq ". + {starts: $starts, last_start: $now}" 2>/dev/null)
  stats=$(echo "$stats" | jq ".[\"$agent\"] = $agent_stats" 2>/dev/null)
  write_stats "$stats"
}

log "supervisor started (n=$n, interval=${interval}s)"

while true; do
  # 1. Check busd
  if [ -f "$busdir/busd.pid" ]; then
    pid=$(cat "$busdir/busd.pid")
    if ! kill -0 "$pid" 2>/dev/null; then
      log "busd dead (pid $pid), restarting"
      nohup "$self_dir/busd" > /dev/null 2>&1 &
      echo $! > "$busdir/busd.pid"
    fi
  else
    nohup "$self_dir/busd" > /dev/null 2>&1 &
    echo $! > "$busdir/busd.pid"
  fi

  # 2. Check each agent window
  for i in $(seq 1 "$n"); do
    win="a$i"
    if ! tmux list-windows -F '#{window_name}' 2>/dev/null | grep -qx "$win"; then
      log "window $win missing, recreating"
      tmux new-window -d -n "$win" "export PATH=\"\$HOME/.agents/bin:\$PATH\"; exec zsh -i -c \"crush --yolo\""
      record_crash "$win"
      continue
    fi
    pane="$(tmux capture-pane -t "$win" -p 2>/dev/null)"
    if [ -z "$pane" ] || echo "$pane" | grep -q "zsh: no such job\|process.*exited\|command not found"; then
      log "$win seems dead, restarting Crush"
      record_crash "$win"
      restart_agent "$win"
      continue
    fi

    # Stuck agent detection — compare pane excluding the permanent footer
    local inbox_files=$(ls "$busdir/$win/in/" 2>/dev/null | wc -l)
    local has_queue=$(echo "$pane" | grep -c "▶.*Queued" 2>/dev/null || echo 0)

    # Compare pane body (excluding footer lines :::, ! Yolo mode!, esc/footer)
    local pane_body=$(echo "$pane" | head -n -3 2>/dev/null)
    local pane_sig=$(echo "$pane_body" | md5sum | cut -d' ' -f1)
    local prev_sig_file="$busdir/.supervisor-$win-sig"
    local prev_sig=$(cat "$prev_sig_file" 2>/dev/null || echo "")
    echo "$pane_sig" > "$prev_sig_file"

    if [ "$inbox_files" -gt 0 ] || [ "$has_queue" -gt 0 ]; then
      # Has pending work — check if frozen or ignoring
      if [ "$pane_sig" = "$prev_sig" ] && [ -n "$prev_sig" ]; then
        # Pane unchanged for >30s = frozen
        local frozen_file="$busdir/.supervisor-$win-frozen"
        local frozen_time=$(cat "$frozen_file" 2>/dev/null || echo 0)
        local now=$(date +%s)
        if [ "$frozen_time" -eq 0 ]; then
          echo "$now" > "$frozen_file"
        elif [ $((now - frozen_time)) -gt 30 ]; then
          log "$win frozen for ${now}s (pending=$inbox_files queue=$has_queue), cancelling"
          # Log the stuck command for analysis
          local stuck_cmd=$(echo "$pane" | tail -3 | tr -d '\n' | head -c 120)
          log "STUCK_CMD [$win]: $stuck_cmd"
          # Send Escape twice to cancel any running command
          tmux send-keys -t "$win" Escape
          sleep 0.3
          tmux send-keys -t "$win" Escape
          sleep 0.3
          # Teach: tell agent to background long commands
          echo "⚠️ That command was taking too long. Next time use '&' to background it (e.g.: ffmpeg ... &). Continue with your task." > "$busdir/$win/in/.supervisor-unstick"
          log "$win: cancelled frozen command, sent unstick message"
          rm -f "$frozen_file" "$busdir/.supervisor-$win-wait"
        fi
      else
        # Pane changed — agent is working, clear frozen state
        rm -f "$busdir/.supervisor-$win-frozen" "$busdir/.supervisor-$win-wait"
      fi
    else
      # No pending work, clear frozen state
      rm -f "$busdir/.supervisor-$win-frozen" "$busdir/.supervisor-$win-wait" 2>/dev/null
    fi
  done

  # 3. Check webui
  if ! pgrep -f "server\\.js" > /dev/null 2>&1; then
    log "webui dead, restarting"
    nohup node "$self_dir/../web/server.js" > /dev/null 2>&1 &
    log "webui restarted"
  fi

  # 4. Check task-runner
  if ! pgrep -f "task-runner" > /dev/null 2>&1; then
    log "task-runner dead, restarting"
    nohup "$self_dir/task-runner" > /dev/null 2>&1 &
    log "task-runner restarted"
  fi

  # 5. Check for stuck tasks (pending > 60s in a1/tasks/)
  for f in "$busdir/a1/tasks/"*; do
    [ -f "$f" ] || continue
    age=$(( $(date +%s) - $(stat -c %Y "$f" 2>/dev/null || echo 0) ))
    if [ "$age" -gt 60 ]; then
      log "stuck task: $(basename $f) (${age}s old), touching"
      touch "$f" 2>/dev/null
    fi
  done

  # 6. Protocol compliance check — verify inter-agent communication
  if [ -f "$busdir/history/messages.log" ]; then
    local now=$(date +%s)
    local recent=$(tail -20 "$busdir/history/messages.log" 2>/dev/null)

    # Check for cascade violations: agent telling another agent to create an agent
    if echo "$recent" | grep -qiE "(create|add|spawn).*(agent|a[0-9])" 2>/dev/null; then
      local cascade_msg=$(echo "$recent" | grep -iE "(create|add|spawn).*(agent|a[0-9])" | tail -1)
      log "PROTOCOL VIOLATION (cascade): $cascade_msg"
    fi

    # Check for unverified tasks: task written to a1/tasks/ but no "checker" response in last 5min
    local last_task=$(ls -t "$busdir/a1/tasks/" 2>/dev/null | head -1)
    if [ -n "$last_task" ]; then
      local task_age=$(( $(date +%s) - $(stat -c %Y "$busdir/a1/tasks/$last_task" 2>/dev/null || echo 0) ))
      if [ "$task_age" -gt 120 ]; then
        # Check if there's a "say checker" in recent history
        if ! echo "$recent" | grep -qi "say checker" 2>/dev/null; then
          log "PROTOCOL VIOLATION (unverified): task $last_task pending >120s without checker notification"
        fi
      fi
    fi
  fi

  # 7. Video stream health check
  local streamer_pid=$(pgrep -f "roll-video\|video-streamer" 2>/dev/null | head -1)
  local fifo="/tmp/video-cache/current.mp4"
  local stream_active=false

  if [ -n "$streamer_pid" ]; then
    # Process is running — check if it's actually writing
    if [ -p "$fifo" ] || [ -f "$fifo" ]; then
      local mtime=$(stat -c %Y "$fifo" 2>/dev/null || echo 0)
      local age=$(( $(date +%s) - mtime ))
      if [ "$age" -lt 30 ]; then
        stream_active=true
      fi
    fi
  fi

  # Track stream status changes to avoid spamming
  local prev_status="$busdir/.supervisor-stream-status"
  local last_status=$(cat "$prev_status" 2>/dev/null || echo "ok")

  if [ "$stream_active" = false ]; then
    if [ "$last_status" != "down" ]; then
      log "video stream DOWN (streamer=$streamer_pid, fifo_age=${age:-?})"
      notify_agent "a3" "Stream health check: stream is down. Please fix and restart." 120
      echo "down" > "$prev_status"
    fi
  else
    if [ "$last_status" = "down" ]; then
      log "video stream RECOVERED"
      notify_agent "a3" "Stream is healthy again." 120
    fi
    echo "ok" > "$prev_status"
  fi

  # ── Write agent states for dashboard ──
  python3.12 -c "
import json, os, time
bus = '$busdir'
n = $n
states = {}
for i in range(1, n+1):
    win = f'a{i}'
    try:
        inbox = len(os.listdir(f'{bus}/{win}/in')) if os.path.isdir(f'{bus}/{win}/in') else 0
    except:
        inbox = 0
    frozen_file = f'{bus}/.supervisor-{win}-frozen'
    frozen_time = 0
    if os.path.isfile(frozen_file):
        try:
            frozen_time = int(open(frozen_file).read().strip())
        except:
            pass
    now = int(time.time())
    # Capture pane via tmux
    import subprocess
    try:
        pane = subprocess.check_output(['tmux', 'capture-pane', '-t', win, '-p'], stderr=subprocess.DEVNULL, timeout=2).decode()
    except:
        pane = ''

    status = 'offline'
    change_ts = 0

    if ':::' in pane:
        status = 'idle'
        sig_file = f'{bus}/.supervisor-{win}-sig'
        if os.path.isfile(sig_file):
            change_ts = int(os.path.getmtime(sig_file))
    elif frozen_time > 0 and (now - frozen_time) > 30:
        status = 'frozen'
        change_ts = frozen_time
    elif inbox > 0:
        status = 'running'
        change_ts = now
    elif pane:
        status = 'thinking'
        sig_file = f'{bus}/.supervisor-{win}-sig'
        if os.path.isfile(sig_file):
            change_ts = int(os.path.getmtime(sig_file))

    age_str = ''
    if change_ts > 0:
        age = now - change_ts
        if age < 60: age_str = f'{age}s ago'
        elif age < 3600: age_str = f'{age//60}m ago'
        else: age_str = f'{age//3600}h ago'

    states[win] = {'status': status, 'pending': inbox}
    if age_str:
        states[win]['last_change'] = age_str

with open(f'{bus}/agent-states.json', 'w') as f:
    json.dump(states, f, indent=2)
" 2>/dev/null

  sleep "$interval"
done
